# Classic Annotea query (Algae2 HOWTO), modernized to Algae 3.
ns rdf=<http://www.w3.org/1999/02/22-rdf-syntax-ns#>
ns d1=<http://purl.org/dc/elements/1.1/>
ns a=<http://www.w3.org/2000/10/annotation-ns#>

load <data/annotations.ttl>

ask (
  ?annot rdf:type <http://www.w3.org/2000/10/annotation-ns#Annotation> ;
         d1:creator "Joe" ;
         a:annotates ?doc .
)
collect (?annot ?doc)
