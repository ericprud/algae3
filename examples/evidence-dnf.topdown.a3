# compiled from SPARQL (sparql-to-algae3.md section 3, top-down)
require <http://www.w3.org/ns/algae3#eval-topdown>
prefix ex: <http://a.example/ns#>
prefix ev: <http://a.example/evidence#>
prefix xsd: <http://www.w3.org/2001/XMLSchema#>
base <file:>
load <file:data/evidence-rules.ttl>
load <file:data/evidence-groups.ttl>
load <file:data/evidence.ttl>

ask ( ( ?rule a <http://a.example/ns#Rule> ;
              <http://a.example/ns#action> ?_bn_g_0 .
        ?_bn_g_0 <http://a.example/ns#message> ?message .
        ( scope ( ask ( scope ( ask ( ?rule <http://a.example/ns#selector> ?selector .
                          ( scope ( ask ( scope ( ask ( ?selector <http://a.example/ns#or> ?disjunct .
                                            ( scope ( ask ( scope ( ask ( ?disjunct <http://a.example/ns#and> ?conjunct .
                                                              ( ( bindings (?evidence) { (<http://a.example/evidence#1>) (<http://a.example/evidence#OBS-2214>) (<http://a.example/evidence#RNC-0859.1>) (<http://a.example/evidence#2>) } .
                                                                  ?conjunct <http://a.example/ns#polarity> <http://a.example/ns#pos> ;
                                                                            <http://a.example/ns#evidenceGroup> ?group .
                                                                  ?group <http://a.example/ns#member> ?membership .
                                                                  ?membership <http://a.example/ns#evidence> ?evidence
                                                                |&
                                                                  ( bindings (?evidence) { (<http://a.example/evidence#1>) (<http://a.example/evidence#OBS-2214>) (<http://a.example/evidence#RNC-0859.1>) (<http://a.example/evidence#2>) } .
                                                                  ?conjunct <http://a.example/ns#polarity> <http://a.example/ns#neg> ;
                                                                            <http://a.example/ns#evidenceGroup> ?_bn_g_1
                                                                    |! ( ?conjunct <http://a.example/ns#evidenceGroup> ?group .
                                                                       ?group <http://a.example/ns#member> ?membership .
                                                                       ?membership <http://a.example/ns#evidence> ?evidence ) ) )
                                                              |&
                                                                bindings (?evidence) { (<http://a.example/evidence#1>) (<http://a.example/evidence#OBS-2214>) (<http://a.example/evidence#RNC-0859.1>) (<http://a.example/evidence#2>) } .
                                                                ?conjunct <http://a.example/ns#polarity> ?polarity ;
                                                                          <http://a.example/ns#attribute> ?pred ;
                                                                          ?comparator ?threshold .
                                                                {oneof(?comparator, <http://a.example/ns#eq>, <http://a.example/ns#lt>, <http://a.example/ns#gt>, <http://a.example/ns#le>, <http://a.example/ns#ge>)} .
                                                                ?evidence ?pred ?actual .
                                                                let (?cmpPass if((?comparator == <http://a.example/ns#eq>), (?actual == ?threshold), if((?comparator == <http://a.example/ns#lt>), (?actual < ?threshold), if((?comparator == <http://a.example/ns#gt>), (?actual > ?threshold), if((?comparator == <http://a.example/ns#le>), (?actual <= ?threshold), if((?comparator == <http://a.example/ns#ge>), (?actual >= ?threshold), false)))))) .
                                                                {((?polarity == <http://a.example/ns#pos>) == ?cmpPass)}
                                                              |&
                                                                ( bindings (?evidence) { (<http://a.example/evidence#1>) (<http://a.example/evidence#OBS-2214>) (<http://a.example/evidence#RNC-0859.1>) (<http://a.example/evidence#2>) } .
                                                                  ?conjunct <http://a.example/ns#polarity> <http://a.example/ns#pos> ;
                                                                            <http://a.example/ns#type> ?requiredType .
                                                                  ?evidence a ?requiredType
                                                                |&
                                                                  ( bindings (?evidence) { (<http://a.example/evidence#1>) (<http://a.example/evidence#OBS-2214>) (<http://a.example/evidence#RNC-0859.1>) (<http://a.example/evidence#2>) } .
                                                                  ?conjunct <http://a.example/ns#polarity> <http://a.example/ns#neg> ;
                                                                            <http://a.example/ns#type> ?_bn_g_2
                                                                    |! ( ?conjunct <http://a.example/ns#type> ?requiredType .
                                                                       ?evidence a ?requiredType ) ) ) ) )
                                                              collect (?evidence ?disjunct ?conjunct)
                                                                order by ?conjunct
                                                            ) share (?evidence ?disjunct ?conjunct) )
                                                      collect (?evidence ?disjunct (count(?conjunct) as ?conjunctsPassed) (concat(if(isIRI(?disjunct), strafter(str(?disjunct), "#"), "[]"), "(", group_concat(if(isIRI(?conjunct), strafter(str(?conjunct), "#"), "[]"), "∧"), ")") as ?disjLog))
                                                        by (?evidence ?disjunct)
                                                    ) share (?evidence ?disjunct ?conjunctsPassed ?disjLog) ) .
                                            ( scope ( ask ( ?disjunct <http://a.example/ns#and> ?conjunct )
                                                      collect (?disjunct (count() as ?conjunctCount))
                                                        by (?disjunct)
                                                    ) share (?disjunct ?conjunctCount) ) .
                                            {(?conjunctsPassed == ?conjunctCount)} .
                                            let (?disjLogStr str(?disjLog)) )
                                            collect (?evidence ?selector ?disjunct ?disjLogStr)
                                              order by ?disjunct
                                          ) share (?evidence ?selector ?disjunct ?disjLogStr) )
                                    collect (?evidence ?selector (concat(if(isIRI(?selector), strafter(str(?selector), "#"), "[]"), "(", if(isIRI(?evidence), strafter(str(?evidence), "#"), "[]"), ", ", group_concat(?disjLogStr, "∨"), ")") as ?selLog))
                                      by (?evidence ?selector)
                                  ) share (?evidence ?selector ?selLog) ) .
                          let (?selLogStr str(?selLog)) )
                          collect (?rule ?selector ?evidence ?selLogStr)
                            order by ?selector
                        ) share (?rule ?selector ?evidence ?selLogStr) )
                  collect (?rule (count(?selector) as ?selectorsPassed) (concat(if(isIRI(?rule), strafter(str(?rule), "#"), "[]"), "(", group_concat(?selLogStr, " + "), ")") as ?log) (group_concat(if(isIRI(?evidence), strafter(str(?evidence), "#"), "[]"), ", ") as ?evidences))
                    by (?rule)
                ) share (?rule ?selectorsPassed ?log ?evidences) ) .
        ( scope ( ask ( ?rule <http://a.example/ns#selector> ?selector )
                  collect (?rule (count() as ?selectorCount))
                    by (?rule)
                ) share (?rule ?selectorCount) ) .
        {(?selectorCount == ?selectorsPassed)} ) )
collect ((strafter(str(?rule), "#") as ?ruleHash) ?message ?evidences ?log)
  order by ?message ?evidences ?ruleHash
